+body {
+  font-family: -apple-system, system-ui, 'Segoe UI', Roboto, sans-serif;
+  background: #1a1018;
+  color: #fff;
+  min-height: 100vh;
+  display: flex;
+  flex-direction: column;
+}
+.top-bar {
+  background: #412234;
+  height: 56px;
+  width: 100%%;
+  flex-shrink: 0;
+}
+.hero {
+  width: 100%%;
+  height: 240px;
+  overflow: hidden;
