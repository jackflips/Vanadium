+}  // namespace
+
+// static
+std::unique_ptr<BlockedDomainsNavigationThrottle>
+BlockedDomainsNavigationThrottle::MaybeCreateThrottleFor(
+    content::NavigationHandle* navigation_handle) {
+  if (!navigation_handle->IsInMainFrame())
+    return nullptr;
+  return std::make_unique<BlockedDomainsNavigationThrottle>(navigation_handle);
+}
+
+BlockedDomainsNavigationThrottle::BlockedDomainsNavigationThrottle(
+    content::NavigationHandle* navigation_handle)
+    : NavigationThrottle(navigation_handle) {}
+
+BlockedDomainsNavigationThrottle::~BlockedDomainsNavigationThrottle() = default;
+
+content::NavigationThrottle::ThrottleCheckResult
+BlockedDomainsNavigationThrottle::WillStartRequest() {
+  return CheckBlockedDomain();
+}
+
+content::NavigationThrottle::ThrottleCheckResult
+BlockedDomainsNavigationThrottle::WillRedirectRequest() {
+  return CheckBlockedDomain();
+}
+
+const char* BlockedDomainsNavigationThrottle::GetNameForLogging() {
+  return "BlockedDomainsNavigationThrottle";
+}
+
+content::NavigationThrottle::ThrottleCheckResult
+BlockedDomainsNavigationThrottle::CheckBlockedDomain() {
+  const GURL& url = navigation_handle()->GetURL();
+  if (!url.SchemeIsHTTPOrHTTPS())
+    return PROCEED;
+
+  const std::string host = url.host();
+  if (IsBlockedDomain(host)) {
+    return ThrottleCheckResult(CANCEL, net::ERR_BLOCKED_BY_ADMINISTRATOR,
+                               GetBlockedPageHTML(host));
+  }
+  return PROCEED;
+}
+
+// static
+const base::flat_set<std::string>&
+BlockedDomainsNavigationThrottle::GetBlockedDomains() {
+  static base::NoDestructor<base::flat_set<std::string>> domains([] {
+    std::string_view data(blocked_domains::kBlockedDomainsData,
+                          blocked_domains::kBlockedDomainsDataSize);
+    std::vector<std::string> domain_list;
+    for (const auto& piece :
+         base::SplitStringPiece(data, "\n", base::TRIM_WHITESPACE,
+                                base::SPLIT_WANT_NONEMPTY)) {
+      domain_list.emplace_back(piece);
+    }
+    return base::flat_set<std::string>(std::move(domain_list));
+  }());
+  return *domains;
+}
+
+// static
+bool BlockedDomainsNavigationThrottle::IsBlockedDomain(
+    const std::string& host) {
+  const auto& domains = GetBlockedDomains();
+  // Check exact match first.
+  if (domains.contains(host))
+    return true;
+  // Check parent domains (e.g., if "facebook.com" is blocked,
+  // "m.facebook.com" should also be blocked).
+  std::string_view remaining(host);
+  while (true) {
+    auto dot = remaining.find('.');
+    if (dot == std::string_view::npos)
+      break;
+    remaining = remaining.substr(dot + 1);
+    if (domains.contains(std::string(remaining)))
+      return true;
+  }
+  return false;
+}
+
+// static
+std::string BlockedDomainsNavigationThrottle::GetBlockedPageHTML(
+    const std::string& host) {
+  // Cycle through images deterministically.
+  static std::atomic<size_t> counter{0};
+  size_t idx = counter.fetch_add(1, std::memory_order_relaxed) %
+               kNumBlockedPageImages;
+  return base::StringPrintf(kBlockedPageTemplate,
+                            kBlockedPageImages[idx], host.c_str());
+}
