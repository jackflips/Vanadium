+#ifndef VANADIUM_BLOCKED_DOMAINS_BLOCKED_DOMAINS_DATA_H_
+#define VANADIUM_BLOCKED_DOMAINS_BLOCKED_DOMAINS_DATA_H_
+
+#include <stddef.h>
+
+namespace blocked_domains {
+
+// Newline-separated sorted list of blocked domains, compiled from
+// StevenBlack/hosts and polarhive/arceo blocklists.
+extern const char kBlockedDomainsData[];
