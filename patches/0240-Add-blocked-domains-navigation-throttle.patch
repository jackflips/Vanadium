+#ifndef CHROME_BROWSER_BLOCKED_DOMAINS_BLOCKED_DOMAINS_NAVIGATION_THROTTLE_H_
+#define CHROME_BROWSER_BLOCKED_DOMAINS_BLOCKED_DOMAINS_NAVIGATION_THROTTLE_H_
+
+#include <memory>
+#include <string>
+
+#include "base/containers/flat_set.h"
+#include "content/public/browser/navigation_throttle.h"
+
+namespace content {
+class NavigationHandle;
+}
+
+class BlockedDomainsNavigationThrottle : public content::NavigationThrottle {
+ public:
+  static std::unique_ptr<BlockedDomainsNavigationThrottle>
+  MaybeCreateThrottleFor(content::NavigationHandle* navigation_handle);
+
+  ~BlockedDomainsNavigationThrottle() override;
+
+  // NavigationThrottle:
+  ThrottleCheckResult WillStartRequest() override;
+  ThrottleCheckResult WillRedirectRequest() override;
+  const char* GetNameForLogging() override;
+
+ private:
+  explicit BlockedDomainsNavigationThrottle(
+      content::NavigationHandle* navigation_handle);
+
+  ThrottleCheckResult CheckBlockedDomain();
+
+  static const base::flat_set<std::string>& GetBlockedDomains();
+  static bool IsBlockedDomain(const std::string& host);
+  static std::string GetBlockedPageHTML(const std::string& host);
+};
