+Generate blocked_domains_data.cc from blocked_domains.txt.
+
+This is invoked by GN as a build action. It reads a newline-separated list
+of domains and generates a C++ source file with the data as a single
+string constant suitable for runtime parsing.
+"""
+
+import sys
+
+
+def main():
+    input_path = sys.argv[1]
+    output_path = sys.argv[2]
+
+    with open(input_path, 'r') as f:
+        domains = sorted(set(
+            line.strip().lower()
+            for line in f
+            if line.strip() and not line.startswith('#')
+        ))
+
+    with open(output_path, 'w') as out:
+        out.write('// Generated file - do not edit.\n')
+        out.write('// Built from blocked_domains.txt\n\n')
+        out.write('#include "vanadium/blocked_domains/blocked_domains_data.h"\n\n')
+        out.write('namespace blocked_domains {\n\n')
+        out.write('const char kBlockedDomainsData[] =\n')
+        for domain in domains:
+            # Escape any special chars (shouldn't be any in domain names)
+            escaped = domain.replace('\\', '\\\\').replace('"', '\\"')
+            out.write(f'    "{escaped}\\n"\n')
+        out.write('    ;\n\n')
+        out.write(f'const size_t kBlockedDomainsDataSize = sizeof(kBlockedDomainsData) - 1;\n\n')
+        out.write('}  // namespace blocked_domains\n')
+
+
+if __name__ == '__main__':
+    main()
