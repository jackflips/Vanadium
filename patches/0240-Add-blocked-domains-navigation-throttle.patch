diff --git a/vanadium/blocked_domains/BUILD.gn b/vanadium/blocked_domains/BUILD.gn
new file mode 100644
index 0000000..ab15094
--- /dev/null
+++ b/vanadium/blocked_domains/BUILD.gn
@@ -0,0 +1,20 @@
+# Copyright 2026 Dumb Browser
+
+import("//build/config/android/rules.gni")
+
+action("generate_blocked_domains_data") {
+  script = "generate_blocked_domains_data.py"
+  inputs = [ "blocked_domains.txt" ]
+  outputs = [ "$target_gen_dir/blocked_domains_data.cc" ]
+  args = [
+    rebase_path("blocked_domains.txt", root_build_dir),
+    rebase_path("$target_gen_dir/blocked_domains_data.cc", root_build_dir),
+  ]
+}
+
+source_set("blocked_domains_data") {
+  sources = [ "blocked_domains_data.h" ]
+  # The generated .cc file is listed as a source from the gen dir.
+  sources += [ "$target_gen_dir/blocked_domains_data.cc" ]
+  deps = [ ":generate_blocked_domains_data" ]
+}
