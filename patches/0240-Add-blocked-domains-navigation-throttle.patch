+.hero-overlay {
+  position: absolute;
+  bottom: 0;
+  left: 0;
+  right: 0;
+  height: 100px;
+  background: linear-gradient(transparent, #1a1018);
+}
+.content {
+  flex: 1;
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  padding: 24px 24px 0;
+  text-align: center;
+}
+.icon {
+  width: 56px;
+  height: 56px;
+  border-radius: 50%%;
+  background: #412234;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  margin-bottom: 20px;
+  margin-top: -28px;
+  position: relative;
+  z-index: 1;
+  box-shadow: 0 4px 24px rgba(65, 34, 52, 0.6);
+}
+.icon svg {
+  width: 28px;
+  height: 28px;
+  fill: #DABFFF;
+}
+h1 {
+  font-size: 21px;
+  font-weight: 400;
