+// Beautiful blocked page with plum theme.
+constexpr char kBlockedPageTemplate[] = R"(
+<!DOCTYPE html>
+<html>
+<head>
+<meta charset="utf-8">
+<meta name="viewport" content="width=device-width, initial-scale=1">
+<title>Site Blocked</title>
+<style>
