diff --git a/third_party/zxing_core/BUILD.gn b/third_party/zxing_core/BUILD.gn
new file mode 100644
index 0000000000000..1b59e5850400d
--- /dev/null
+++ b/third_party/zxing_core/BUILD.gn
@@ -0,0 +1,8 @@
